{
  "name": "walkthru-website",
  "version": "1.0.0",
  "private": true,
  "description": "Walkthru Earth - People-First Urban Intelligence Platform",
  "author": "Walkthru Earth",
  "license": "CC-BY-4.0",
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "eslint --cache --cache-location .next/cache/eslint/",
    "lint:fix": "eslint --fix",
    "type-check": "tsc --noEmit",
    "format": "prettier --write .",
